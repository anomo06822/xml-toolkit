{
  "name": "datatoolkit",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "anomo06822",
  "description": "Professional multi-format data toolkit for XML, JSON, and Markdown",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm:dev:web\" \"wait-on tcp:3000 && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "electron:dev:backend": "cross-env ELECTRON_BACKEND_DEV=1 npm run electron:dev",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder",
    "desktop:dist:mac": "npm run build && electron-builder --mac dmg",
    "desktop:dist:win": "npm run build && electron-builder --win nsis",
    "desktop:dist:mac:ci": "npm run build && electron-builder --mac dmg --publish never",
    "desktop:dist:win:ci": "npm run build && electron-builder --win nsis --publish never",
    "backend:run": "dotnet run --project backend/DataToolkit.Api/DataToolkit.Api.csproj --urls http://127.0.0.1:5188",
    "backend:publish:mac": "dotnet publish backend/DataToolkit.Api/DataToolkit.Api.csproj -c Release -r osx-arm64 --self-contained true /p:PublishSingleFile=true /p:PublishTrimmed=false -o backend/publish/mac",
    "backend:publish:win": "dotnet publish backend/DataToolkit.Api/DataToolkit.Api.csproj -c Release -r win-x64 --self-contained true /p:PublishSingleFile=true /p:PublishTrimmed=false -o backend/publish/win",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "electron-updater": "^6.3.9",
    "github-markdown-css": "^5.8.1",
    "lucide-react": "^0.554.0",
    "marked": "^17.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^28.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.3"
  },
  "keywords": [
    "xml",
    "json",
    "markdown",
    "formatter",
    "converter",
    "diff",
    "visualizer"
  ]
}
