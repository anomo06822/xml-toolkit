# DataToolkit Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================
# Application Settings
# ==============================================

# Port for the application
APP_PORT=3000

# Domain name (for Traefik routing)
APP_DOMAIN=localhost

# ==============================================
# API Keys
# ==============================================

# Google Gemini API Key for AI features
GEMINI_API_KEY=${GEMINI_API_KEY}

# Optional Electron backend URL override
ELECTRON_BACKEND_URL=http://127.0.0.1:5188

# ==============================================
# Nginx Settings (if using with-nginx profile)
# ==============================================

NGINX_PORT=8080
NGINX_SSL_PORT=8443

# ==============================================
# Build Settings
# ==============================================

NODE_ENV=production
