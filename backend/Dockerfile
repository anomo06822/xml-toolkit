FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build

WORKDIR /src

COPY backend/DataToolkit.Api/DataToolkit.Api.csproj backend/DataToolkit.Api/
RUN dotnet restore backend/DataToolkit.Api/DataToolkit.Api.csproj

COPY backend/DataToolkit.Api/ backend/DataToolkit.Api/
WORKDIR /src/backend/DataToolkit.Api
RUN dotnet publish DataToolkit.Api.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime

WORKDIR /app
ENV ASPNETCORE_URLS=http://0.0.0.0:8080

COPY --from=build /app/publish .

EXPOSE 8080

ENTRYPOINT ["dotnet", "DataToolkit.Api.dll"]
